</verifier-result>`}const Cq=[Iq,yq],wq='<div style="padding:40px;color:#999;font-family:system-ui">Design will appear here…</div>',Eq=`function Slides({ children }) {
  // Root.sc.html is parsed as JSX so the whitespace between slide elements
  // becomes string children. Filter those out — otherwise slides.length is
  // ~2x the real count and the n/total counter goes haywire.
  const slides = React.Children.toArray(children).filter(
    (c) => typeof c !== 'string' || c.trim() !== '',
  );
  const [idx, setIdx] = React.useState(0);
  const userTookControl = React.useRef(false);
  const prevCount = React.useRef(slides.length);

  // Fit the 1280x720 stage to the viewport with letterboxing. ResizeObserver
  // on the outer fixed container so we react to window resizes and any
  // parent layout changes. Allow scaling above 1 — slides should fill.
  const outerRef = React.useRef(null);
  const [scale, setScale] = React.useState(1);
  React.useEffect(() => {
    const el = outerRef.current;
    if (!el) return;
    const update = () => {
      const w = el.clientWidth;
      const h = el.clientHeight;
      if (!w || !h) return;
      setScale(Math.min(w / 1280, h / 720));
    };
    update();
    const ro = new ResizeObserver(update);
    ro.observe(el);
    return () => ro.disconnect();
  }, []);

  // During streaming the model is writing slide N while the user is
  // looking at slide 1. Auto-advance to the tail until the user grabs
  // control, so they see the new content as it arrives.
  React.useEffect(() => {
    if (slides.length > prevCount.current && !userTookControl.current) {
      setIdx(slides.length - 1);
    }
    prevCount.current = slides.length;
  }, [slides.length]);

  const total = slides.length || 1;
  const safeIdx = Math.max(0, Math.min(idx, total - 1));

  const go = React.useCallback(
    (next) => {
      userTookControl.current = true;
      setIdx(Math.max(0, Math.min(total - 1, next)));
    },
    [total],
  );

  React.useEffect(() => {
    const onKey = (e) => {
      if (e.key === 'ArrowLeft') go(safeIdx - 1);
      else if (e.key === 'ArrowRight' || e.key === ' ') go(safeIdx + 1);
    };
    window.addEventListener('keydown', onKey);
    return () => window.removeEventListener('keydown', onKey);
  }, [safeIdx, go]);

  return (
    <div
      ref={outerRef}
      style={{
        position: 'fixed',
        inset: 0,
        background: '#f0f0f0',
        display: 'flex',
        alignItems: 'center',
        justifyContent: 'center',
        fontFamily: 'system-ui',
      }}
    >
      <div
        style={{
          width: 1280,
          height: 720,
          background: 'white',
          borderRadius: 12,
          boxShadow: '0 20px 60px rgba(0,0,0,0.15)',
          position: 'relative',
          overflow: 'hidden',
          transform: \`scale(\${scale})\`,
          transformOrigin: 'center center',
          flexShrink: 0,
        }}
      >
        {slides.map((child, i) => (
          <div
            key={i}
            style={{
              position: 'absolute',
              inset: 0,
              display: i === safeIdx ? 'flex' : 'none',
              alignItems: 'center',
              justifyContent: 'center',
            }}
          >
            {child}
          </div>
        ))}
        <div
          style={{
            position: 'absolute',
            bottom: 24,
            left: '50%',
            transform: 'translateX(-50%)',
            display: 'flex',
            alignItems: 'center',
            gap: 12,
            background: 'rgba(0,0,0,0.6)',
            backdropFilter: 'blur(8px)',
            WebkitBackdropFilter: 'blur(8px)',
            color: 'white',
            padding: '8px 16px',
            borderRadius: 24,
            fontSize: 13,
          }}
        >
          <button
            onClick={() => go(safeIdx - 1)}
            style={{
              background: 'transparent',
              border: 'none',
              color: 'white',
              cursor: 'pointer',
              fontSize: 18,
              padding: '0 4px',
            }}
          >
            ←
          </button>
          <span style={{ fontVariantNumeric: 'tabular-nums', minWidth: 48, textAlign: 'center' }}>
            {safeIdx + 1} / {total}
          </span>
          <button
            onClick={() => go(safeIdx + 1)}
            style={{
              background: 'transparent',
              border: 'none',
              color: 'white',
              cursor: 'pointer',
              fontSize: 18,
              padding: '0 4px',
            }}
          >
            →
          </button>
        </div>
      </div>
    </div>
  );
}
module.exports = { default: Slides };
`,vq=`function Canvas({ children }) {
  // Root.sc.html JSX includes whitespace text nodes between frame elements;
