(function () {
  const React = window.React;
  const h = React.createElement;

  // ───────────────────────────── registry ───────────────────────────────────
  // One entry per component name. \`ver\` is bumped on any change so mounted
  // wrappers can cheaply subscribe + re-render without diffing payloads.
  const registry = Object.create(null);
  function reg(name) {
    return (
      registry[name] ||
      (registry[name] = {
        html: '',
        tpl: null,
        Logic: null,
        jsStreaming: false,
        htmlStreaming: false,
        ver: 0,
        subs: new Set(),
