      const hintRaw = node.getAttribute('hint-placeholder-val');
      const hintGet = hintRaw != null ? compileAttr(hintRaw) : null;
      const kids = [...node.childNodes].map(walk).filter(Boolean);
      return (vals, ctx, key) => {
        let v = valGet(vals);
        if (v === undefined && hintGet) v = hintGet(vals);
        return v
          ? h(
              React.Fragment,
              { key },
              kids.map((b, j) => b(vals, ctx, j)),
            )
          : null;
      };
    }

    if (tag === 'sc-comp') {
      const name = node.getAttribute('sc-name');
      if (name === 'ExtReactComponent') return compileExt(node);
      const { propGetters, hintSize } = collectProps(node, true);
      const kids = [...node.childNodes].map(walk).filter(Boolean);
      return (vals, ctx, key) => {
        const props = { key, __hintSize: hintSize };
        for (const [k, g] of propGetters) props[k] = g(vals);
        if (kids.length) props.children = kids.map((b, j) => b(vals, ctx, j));
        return h(getScompNamed(name), props);
      };
    }

    // plain DOM element
    const realTag = RAW_UNWRAP[tag] || tag;
    const { propGetters, pseudoClasses } = collectProps(node, false);
    const kids = [...node.childNodes].map(walk).filter(Boolean);
    return (vals, ctx, key) => {
      const props = { key };
      for (const [k, g] of propGetters) {
        let v = g(vals);
        if (k === 'style' && typeof v === 'string') v = cssToObj(v);
        // keep form controls controlled from first render so React doesn't warn
        if ((k === 'value' || k === 'checked') && v === undefined) v = k === 'checked' ? false : '';
        props[k] = v;
      }
      if (pseudoClasses.length)
        props.className = [props.className, ...pseudoClasses].filter(Boolean).join(' ');
      return h(realTag, props, ...kids.map((b, j) => b(vals, ctx, j)));
    };
  }

  function collectProps(node, isComponent) {
    const propGetters = [];
    const pseudoClasses = [];
    let hintSize = null;
    for (const { name, value } of [...node.attributes]) {
      if (name === 'sc-name') continue;
      let key = name;
      if (key.startsWith(CAMEL_ATTR)) key = kebabToCamel(key.slice(CAMEL_ATTR.length));
      if (key === 'hint-size') {
        hintSize = value;
        continue;
      }
      if (key.startsWith('style-')) {
        pseudoClasses.push(pseudoSheet(key.slice(6), value));
        continue;
      }
      if (isComponent) {
        if (key.includes('-')) key = kebabToCamel(key);
      } else {
        if (key === 'class') key = 'className';
        else if (key === 'for') key = 'htmlFor';
        else if (key.startsWith('on'))
          key = EVENT_MAP[key] || 'on' + key[2].toUpperCase() + key.slice(3);
      }
      propGetters.push([key, compileAttr(value)]);
    }
    return { propGetters, pseudoClasses, hintSize };
  }

  function compileExt(node) {
    const url = node.getAttribute('import');
    const exp = node.getAttribute('name') || 'default';
    const { propGetters, hintSize } = collectProps(node, true);
    let Loaded = extCache.get(url + '#' + exp);
    if (Loaded === undefined) {
      extCache.set(url + '#' + exp, null);
      import(/* @vite-ignore */ url)
        .then((m) => {
          extCache.set(url + '#' + exp, m[exp] || m.default);
          for (const n in registry) bump(n); // crude: anything using it re-renders
        })
        .catch(() => {});
    }
    return (vals, ctx, key) => {
      const C = extCache.get(url + '#' + exp);
      if (!C) return h(Placeholder, { key, name: exp, hintSize });
      const props = { key };
      for (const [k, g] of propGetters) if (k !== 'import' && k !== 'name') props[k] = g(vals);
      return h(C, props);
    };
  }
  const extCache = new Map();

  // ───────────────────────────── placeholder ────────────────────────────────
  function Placeholder({ name, hintSize, streaming }) {
    const [w, hgt] = (hintSize || '100%,60px').split(',');
    return h('div', {
      className: 'sc-placeholder' + (streaming ? ' sc-streaming' : ''),
      style: { width: w.trim(), height: hgt && hgt.trim() },
      title: name,
    });
  }

  // ───────────────── logic base class (what .sc.js extends) ─────────────────
  // Mirrors enough of React.Component that authors can use this.state /
  // setState / lifecycle methods, but rendering is delegated to the template
  // via renderVals(). The wrapper owns the actual React state object.
  class StreamableLogic {
    constructor(props) {
      this.props = props || {};
      this.state = {};
    }
    setState(u, cb) {
      this.__host && this.__host.__setLogicState(u, cb);
    }
    forceUpdate() {
      this.__host && this.__host.forceUpdate();
    }
    componentDidMount() {}
    componentDidUpdate() {}
    componentWillUnmount() {}
    renderVals() {
      return {};
    }
  }

  // ───────────────────── the one real React component ───────────────────────
  // The wrapper's own React state is just a re-render tick. The *logic*
  // instance owns this.state — that way an HMR swap can install a new logic
  // (with its own initial state merged over the old) without fighting React's
  // fiber, which would otherwise restore a stale wrapper.state on next render.
  class StreamableComponent extends React.Component {
    constructor(props) {
      super(props);
      this.__name = props.__name;
      this.state = { __v: 0 };
      this.__sub = () => {
        this.__reconcileLogic();
        this.forceUpdate();
      };
      this.__makeLogic(reg(this.__name).Logic, null);
      ensureFetched(this.__name);
    }
    __makeLogic(Logic, prevState) {
      const L = Logic || StreamableLogic;
      this.logic = new L(this.__userProps());
      this.logic.__host = this;
      if (prevState) this.logic.state = { ...(this.logic.state || {}), ...prevState };
    }
    __userProps() {
      const { __name, __hintSize, ...rest } = this.props;
      return rest;
    }
    __setLogicState(u, cb) {
      const prev = this.logic.state;
      const patch = typeof u === 'function' ? u(prev) : u;
      this.logic.state = { ...prev, ...patch };
      this.setState((s) => ({ __v: s.__v + 1 }), cb);
    }
    __reconcileLogic() {
      const Next = reg(this.__name).Logic;
      const Cur = this.logic.constructor;
      if (Next === Cur || (!Next && Cur === StreamableLogic)) return;
      try {
        this.logic.componentWillUnmount();
      } catch (e) {
        console.error(e);
      }
      this.__makeLogic(Next, this.logic.state);
      this.__needsDidMount = true; // fire after the swap commits, so refs exist
    }
    componentDidMount() {
      reg(this.__name).subs.add(this.__sub);
      try {
        this.logic.componentDidMount();
      } catch (e) {
        console.error(e);
      }
    }
    componentDidUpdate(prevProps) {
      this.logic.props = this.__userProps();
      if (this.__needsDidMount) {
        this.__needsDidMount = false;
        try {
          this.logic.componentDidMount();
        } catch (e) {
          console.error(e);
        }
      } else {
        try {
          this.logic.componentDidUpdate(prevProps);
        } catch (e) {
          console.error(e);
        }
      }
    }
    componentWillUnmount() {
      reg(this.__name).subs.delete(this.__sub);
      try {
        this.logic.componentWillUnmount();
      } catch (e) {
        console.error(e);
      }
    }
    render() {
      const r = reg(this.__name);
      const cls =
        'sc-host' +
        (r.htmlStreaming ? ' sc-streaming-html' : '') +
        (r.jsStreaming ? ' sc-streaming-js' : '');
      const hostStyle = r.htmlStreaming ? hintToMin(this.props.__hintSize) : undefined;
      if (!r.tpl)
        return h(
          'div',
          { className: cls, style: hostStyle },
          h(Placeholder, { name: this.__name, hintSize: this.props.__hintSize }),
        );
      this.logic.props = this.__userProps();
      let vals = {};
      try {
        vals = this.logic.renderVals() || {};
      } catch (e) {
        console.error(e);
      }
      return h('div', { className: cls, style: hostStyle }, r.tpl(vals, this));
    }
  }

  function hintToMin(hint) {
    if (!hint) return undefined;
    const [w, hgt] = hint.split(',');
    return { minWidth: w.trim(), minHeight: hgt && hgt.trim() };
  }

  // ─────────────────── plain \`.jsx\` component registry ─────────────────────
  // Parallel to \`registry\` (scomp pairs): names that resolve to a plain React
  // function component loaded from \`\${dir}/Name.jsx\`. No StreamableLogic, no
  // template — just a normal React component that can use hooks and takes
  // \`children\`. Kept separate so the scomp path is untouched.
  const jsxRegistry = Object.create(null);
  function jsxReg(name) {
    return jsxRegistry[name] || (jsxRegistry[name] = { Comp: null, fetched: false });
  }

  // memoised so <Foo/> in two templates yields the same component identity.
  // The wrapper reads from BOTH registries on each render: if a .jsx has
  // landed for this name we render that directly (plain React component);
  // otherwise we fall through to StreamableComponent (scomp pair path).
  // Both disk-fetch paths are kicked on first access — whichever resolves
  // first wins, and the scomp subs list drives re-renders for either.
  const named = new Map();
  function getScompNamed(name) {
    if (named.has(name)) return named.get(name);
    function Dispatcher(p) {
      // Subscribe to bumps so either a jsx or scomp arrival triggers re-render
      // on already-mounted references. Cheap tick state — identity never
      // changes after mount.
      const [, setTick] = React.useState(0);
      React.useEffect(() => {
        const sub = () => setTick((n) => n + 1);
        reg(name).subs.add(sub);
        return () => {
          reg(name).subs.delete(sub);
        };
      }, []);
      const jr = jsxReg(name);
      if (jr.Comp) {
        // Strip scomp-only props so the plain jsx component gets a clean API.
        const { __name, __hintSize, ...rest } = p;
        return h(jr.Comp, rest);
      }
      // Kick both disk paths once per name; whichever 200s first wins.
      ensureFetched(name);
      ensureJsxFetched(name);
      return h(StreamableComponent, { ...p, __name: name });
    }
    Dispatcher.displayName = name;
    named.set(name, Dispatcher);
    return Dispatcher;
  }

  // ─────────────────────────── disk loading ─────────────────────────────────
  const script = document.currentScript;
  const pageBase =
    location.pathname
      .split('/')
      .pop()
      .replace(/\\.html?$/, '') || 'index';
  const compDir = (script && script.dataset.scDir) || document.body.dataset.scDir || pageBase;

  function ensureJsxFetched(name) {
    const jr = jsxReg(name);
    if (jr.fetched) return;
    jr.fetched = true;
    // Try .jsx first, then .tsx. Whichever 200s wins; both 404 = silent
    // no-op and the scomp path (if any) drives the component.
    fetch(compDir + '/' + name + '.jsx')
      .then((res) => (res.ok ? res.text() : ''))
      .then((t) => {
        if (t && !jr.Comp) updateJsx(name, t);
      })
      .catch(() => {});
    fetch(compDir + '/' + name + '.tsx')
      .then((res) => (res.ok ? res.text() : ''))
      .then((t) => {
        if (t && !jr.Comp) updateJsx(name, t);
      })
      .catch(() => {});
  }

  function ensureFetched(name) {
    const r = reg(name);
    if (r.fetched) return;
    r.fetched = true;
    fetch(compDir + '/' + name + '.sc.html')
      .then((res) => (res.ok ? res.text() : ''))
      .then((t) => {
        if (t && !r.html) updateHtml(name, t);
      })
      .catch(() => {});
    fetch(compDir + '/' + name + '.sc.ts')
      .then((res) => (res.ok ? res.text() : ''))
      .then((t) => {
        if (t && !r.Logic) updateJs(name, t);
      })
      .catch(() => {});
  }

  // ─────────────────────────── live updates ─────────────────────────────────
  function updateHtml(name, html) {
    const r = reg(name);
    r.html = html;
    try {
      r.tpl = compileTemplate(html);
    } catch (e) {
      console.warn('template compile failed for', name, e);
    }
    bump(name);
  }

  function updateJs(name, src) {
    const r = reg(name);
    let js = src;
    try {
      if (window.Sucrase) js = window.Sucrase.transform(src, { transforms: ['typescript'] }).code;
      else if (window.Babel)
        js = window.Babel.transform(src, { filename: name + '.ts', presets: ['typescript'] }).code;
    } catch (e) {
      console.warn('TS transform failed for', name, e);
      return;
    }
    let Cls;
    try {
      // nosemgrep: eval-and-function-constructor
      // Intentional: scomps runtime loads model-emitted \`.sc.ts\` logic
      // classes by transpiling TS → JS via Sucrase/Babel and evaluating
      // the resulting source. The entire point of this runtime is to
      // execute model-generated code in the gated fast-mode iframe —
      // \`fast_mode_write\` is behind isFastModeEnabled, and the iframe is
      // sandboxed (\`sandbox="allow-scripts allow-forms ..."\` without
      // \`allow-same-origin\` in prod) so escape from the iframe can't
      // reach the outer claude.ai SPA or its cookies.
      Cls = new Function(
        'StreamableLogic',
        'React',
        js + '\\n;return typeof ' + name + '!=="undefined"?' + name + ':undefined;',
      )(StreamableLogic, React);
    } catch (e) {
      console.warn('JS eval failed for', name, e);
      return;
    }
    if (typeof Cls !== 'function') {
      console.warn('no class', name);
      return;
    }
    r.Logic = Cls;
    bump(name);
  }

  // ───────────────────── .jsx plain-component loader ─────────────────────
  // Transpile JSX → JS via Babel-standalone (react preset), eval in a
  // CommonJS-like shell that gives the source access to \`React\`, \`module\`,
  // \`exports\`, and \`require\` (for sibling helpers via relative import).
  // The file is expected to set \`module.exports\` — either \`{ default: Comp }\`
  // or a named export matching the file basename.
  function updateJsx(name, src) {
    if (!window.Babel) {
      console.warn('Babel standalone not loaded; cannot compile .jsx', name);
      return;
    }
    let code;
    try {
      code = window.Babel.transform(src, {
        filename: name + '.jsx',
        presets: ['react', 'typescript'],
      }).code;
    } catch (e) {
      console.warn('JSX transform failed for', name, e);
      return;
    }
    const module = { exports: {} };
    try {
      // nosemgrep: eval-and-function-constructor
      // Intentional: scomps runtime loads plain \`.jsx\` helper components
      // (e.g. starter-template Slides.jsx / Canvas.jsx) by transpiling via
      // Babel and evaluating the resulting CommonJS source. Same blast-
      // radius story as the \`.sc.ts\` path above — only runs inside the
      // gated fast-mode iframe which is sandboxed without
      // \`allow-same-origin\` in prod.
      new Function('React', 'module', 'exports', 'require', code)(
        React,
        module,
        module.exports,
        () => ({}), // no-op require — plain .jsx files shouldn't import for now
      );
    } catch (e) {
      console.warn('JSX eval failed for', name, e);
      return;
    }
    let Comp = module.exports.default;
    if (!Comp && typeof module.exports[name] === 'function') Comp = module.exports[name];
    if (typeof Comp !== 'function') {
      console.warn('no default export for', name);
      return;
    }
    const jr = jsxReg(name);
    jr.Comp = Comp;
    // Bump the parallel scomp registry entry — Dispatchers subscribed there
    // will re-render and pick up the new jsx component.
    bump(name);
  }

  function setJsStreaming(name, on) {
    reg(name).jsStreaming = !!on;
    bump(name);
  }
  function setHtmlStreaming(name, on) {
    reg(name).htmlStreaming = !!on;
    bump(name);
  }

  // ─────────────────────────────── boot ─────────────────────────────────────
  function boot() {
    const host =
      document.getElementById('sc-root') ||
      (() => {
        const d = document.createElement('div');
        d.id = 'sc-root';
        document.body.appendChild(d);
        return d;
      })();
    const Root = getScompNamed('Root');
    window.ReactDOM.createRoot
      ? window.ReactDOM.createRoot(host).render(h(Root))
      : window.ReactDOM.render(h(Root), host);
  }

  // base CSS (placeholders, redacted interp text, streaming pulse)
  const baseCss = document.createElement('style');
  baseCss.textContent = \`
    .sc-placeholder{background:linear-gradient(90deg,#eee 25%,#f5f5f5 37%,#eee 63%);
      background-size:400% 100%;animation:scShimmer 1.4s ease infinite;border-radius:6px}
    @keyframes scShimmer{0%{background-position:100% 50%}100%{background-position:0 50%}}
    .sc-interp.sc-missing{font-family:"Flow Circular","Redacted Script",monospace;
      background:#eee;color:transparent;border-radius:4px;user-select:none}
  \`;
  document.head.appendChild(baseCss);

  Object.assign(window, {
    __updateComponentHtml: updateHtml,
    __updateComponentJs: updateJs,
    __updateJsxComponent: updateJsx,
    __scompsJsxRegistry: jsxRegistry,
    __setComponentJsStreaming: setJsStreaming,
    __setComponentHtmlStreaming: setHtmlStreaming,
    getScompNamed,
    StreamableLogic,
    StreamableComponent,
    __scompsBoot: boot,
    __scompsRegistry: registry,
  });

  if (document.readyState !== 'loading') boot();
  else document.addEventListener('DOMContentLoaded', boot);
})();
`,Gq=Rq,_q=`You are now in Fast Mode — a design-streaming environment built on the **streaming-components (scomps)** framework. You write React components as two files each, and the user watches them paint live as you type.

# THE FRAMEWORK

A **scomp** is a React component split in two:

| file              | arrives        | contains                          |
|-------------------|----------------|-----------------------------------|
| \`Name.sc.html\`  | char-by-char   | declarative template              |
| \`Name.sc.ts\`    | whole file     | logic class (\`renderVals()\`)    |

The runtime compiles the template into a \`(vals) => ReactNode\` function and pairs it with the logic class inside one real React component. Either half can be missing: no html → sized shimmer placeholder; no ts → template renders against \`{}\` (text holes show as redacted blocks). This means **the page looks reasonable from the very first character of the very first template**.

The entry point is **\`Root\`** — the runtime mounts \`<Root/>\` automatically.

# THE TOOL: fast_mode_write

\`\`\`
fast_mode_write({
  shell: "myapp.html",
  files: [
    { op: "write", path: "myapp/Root.sc.html",   content: "..." },
    { op: "write", path: "myapp/Header.sc.html", content: "..." },
    { op: "write", path: "myapp/Card.sc.html",   content: "..." },
    { op: "write", path: "myapp/Root.sc.ts",     content: "..." },
    { op: "edit",  path: "myapp/Card.sc.html",   find: "<h1>Old</h1>", replace: "<h1>New</h1>" }
  ]
})
\`\`\`

Each entry in \`files\` is one of two operations:

- **\`{op:"write", path, content}\`** — replace the file wholesale. \`.sc.html\` \`content\` STREAMS char-by-char into the live page; the user watches the template grow as you write it. \`.sc.ts\` \`content\` is applied when the file is complete.
- **\`{op:"edit", path, find, replace}\`** — single str_replace. \`find\` MUST be unique in the target (occur exactly once) — duplicate matches are an error. \`.sc.html\` edits stream live as the \`replace\` portion arrives — the user sees the replaced region update in place against the current file. \`.sc.ts\` edits apply on completion.

Edits compose with writes in the same call: write a file then edit it, and the edit runs against the just-written content. Use edits for small surgical changes (one line, one block); use writes for larger rewrites that benefit from the visual streaming effect.

# KEY PRINCIPLES

1. **ONE big fast_mode_write per turn.** Put every component in a single call. Each round-trip is ~1.5s of dead time; one call with 8 files beats 8 calls with 1 file.
2. **All \`.sc.html\` FIRST, then all \`.sc.ts\`.** Templates stream visually; logic doesn't. Writing every template first means the whole page has shape before any logic arrives. EXCEPTION: for visually-crucial containers like canvases or slides renderer, you should stream the logic immediately after writing the HTML, before creating other components, so that these important bits of display logic are online during the bulk of streaming. For example, if Root.sc.html is a slides container or canvas, managing the display of the rest of the components, you must implement Root.sc.ts immediately after, before streaming other components, so people can advance and see slides.
3. **\`Root.sc.html\` is the very first file.** It references the other components by capital-tag name (\`<Header/>\`, \`<Card/>\`) — those render as sized placeholders until their own templates stream in.
4. **Templates are declarative — no JS expressions in holes.** \`{{ user.name }}\` works; \`{{ a + b }}\` does not. Compute in \`renderVals()\`, expose flat values by name.
5. **Surgical updates for follow-ups.** When the user asks for a change, touch only the files that need to change. For one-line / one-block tweaks use \`{op:"edit", find, replace}\` inside fast_mode_write — it streams live, composes with writes in the same call, and avoids re-emitting hundreds of unchanged tokens. For broader rewrites use \`{op:"write"}\` so the user sees the visual streaming effect.

If you see \`[INTERRUPTED MID-STREAM]\` in the tool result, the user typed while you were mid-write. Any \`.sc.html\` that was streaming is **already rendered live with partial content**; any \`.sc.ts\` that was streaming was **NOT applied**. Read what the user said and decide: if it's a **steer** (nudge, refinement, correction), apply it and keep going with the original task. If it's a **question**, answer it and wait. If it's a **different command** or **stop**, abandon the original task and do what they asked instead.

---

# Templates (\`*.sc.html\`)

Templates are HTML with \`{{ path }}\` holes. Paths are **dotted lookups only** — \`{{ user.name }}\`, \`{{ items }}\`, \`{{ $index }}\`. Literals work too: \`{{ true }}\`, \`{{ 3 }}\`, \`{{ "hi" }}\`.

## Attributes

| form                 | result                                            |
|----------------------|---------------------------------------------------|
| \`x="literal"\`      | string                                            |
| \`x="{{ path }}"\`   | the raw value (number, fn, ref, object — anything)|
| \`x="a {{p}} b"\`    | string interpolation                              |

Event handlers and refs are whole-value attrs: \`onClick="{{ handler }}"\`, \`ref="{{ myRef }}"\`. Use **camelCase exactly as in JSX** (\`onClick\`, \`onChange\`). \`class\` and \`for\` are auto-mapped to \`className\` / \`htmlFor\`.

## Control flow

\`\`\`html
<sc-for list="{{ items }}" as="item" hint-placeholder-count="3">
  <Row item="{{ item }}" />        <!-- $index is also in scope -->
</sc-for>

<sc-if value="{{ hasItems }}" hint-placeholder-val="{{ true }}">
  ...
</sc-if>
\`\`\`

The \`hint-*\` attrs decide what to render while the value is still \`undefined\` (logic not loaded yet). Always set them — they're what makes the page look right during streaming.

## Child components

Any tag starting with a capital letter is a scomp reference:

\`\`\`html
<Card item="{{ it }}" onOpen="{{ open }}" hint-size="100%,120px" />
\`\`\`

\`hint-size="w,h"\` sizes the placeholder (and the host's min-size while streaming). All other attrs become props (kebab → camel). **Always set \`hint-size\`** on child references — it's what holds the layout shape before the child's template arrives.

## Styling

Write inline \`style="..."\` (compiled to a React style object). Pseudo-states get their own attrs:

\`\`\`html
<button style="background:#fff;border:1px solid #ddd;padding:8px 16px;border-radius:8px"
        style-hover="background:#eee"
        style-active="transform:scale(.98)">
\`\`\`

Supported: \`style-hover\`, \`style-active\`, \`style-focus\`, \`style-before\`, \`style-after\`.

---

# Logic (\`*.sc.ts\`)

\`\`\`ts
class Counter extends StreamableLogic {
  state = { n: 0 };

  renderVals() {
    return {
      n: this.state.n,
      inc: () => this.setState(s => ({ n: s.n + 1 })),
    };
  }
}
\`\`\`

- The class **must** be named exactly like the component (\`Counter\` ↔ \`Counter.sc.ts\`).
- You get \`this.props\`, \`this.state\`, \`this.setState\`, \`this.forceUpdate\`, \`React\` — same as a class component, minus \`render()\`.
- \`renderVals()\` returns the **template's input**, not JSX. Keep it flat: strings, numbers, booleans, arrays, handlers, refs. **You can also expose React elements as values** — a \`{{ icon }}\` hole whose value is \`<svg …/>\` or \`<MyComp/>\` renders the element directly (not stringified). Useful for passing icons, badges, and other small pre-rendered fragments into a template from the logic side.
- Optional lifecycle: \`componentDidMount\`, \`componentDidUpdate\`, \`componentWillUnmount\`.
- TS is stripped in-browser; types aren't checked.

**Authoring rule of thumb:** if you'd write it in JSX as an expression — a ternary, a \`.map\`, a comparison — move it into \`renderVals()\` and expose the *result* by name. The template stays declarative, which is what lets it render safely while half-written.

## Helper files

If you need shared business logic (formatters, default data, validators), you can write a plain \`.js\` or \`.jsx\` file alongside your scomps and \`import\` it from any \`.sc.ts\` class. Path is relative to the component dir, e.g. \`import { fmtDate } from './helpers.js';\`. **Prefer keeping logic in React component land** — only reach for a helper file when the same code would otherwise be duplicated across multiple scomps or genuinely doesn't belong inside any one component.

---

# Streaming-friendly patterns

## Root references children by name with hint-size

\`\`\`html
<!-- myapp/Root.sc.html -->
<div style="min-height:100vh;display:flex;flex-direction:column">
  <Header hint-size="100%,64px" />
  <main style="flex:1;padding:24px;display:grid;grid-template-columns:repeat(3,1fr);gap:16px">
    <sc-for list="{{ cards }}" as="c" hint-placeholder-count="6">
      <Card item="{{ c }}" hint-size="100%,160px" />
    </sc-for>
  </main>
  <Footer hint-size="100%,48px" />
</div>
\`\`\`

Root paints first: header/footer/card slots are shimmer boxes of the right size. Then \`Header.sc.html\` streams in and replaces its box. Then \`Card.sc.html\`. Then \`Footer.sc.html\`. Then the \`.sc.ts\` files land and the redacted text holes fill with real data.

## sc-for with hint-placeholder-count

For any list, set \`hint-placeholder-count\` to the rough expected length so the grid is sized before \`renderVals()\` provides the real array.

## Per-item logic lives on the item component, not Root

\`\`\`html
<!-- myapp/Card.sc.html -->
<div style="border:1px solid #eee;border-radius:12px;padding:16px"
     style-hover="border-color:#ccc">
  <h3 style="margin:0 0 8px">{{ item.title }}</h3>
  <p style="margin:0;opacity:.6">{{ item.body }}</p>
  <button onClick="{{ toggle }}" style="margin-top:12px">
    <sc-if value="{{ expanded }}">Hide</sc-if>
    <sc-if value="{{ collapsed }}">Show more</sc-if>
  </button>
</div>
\`\`\`

\`\`\`ts
// myapp/Card.sc.ts
class Card extends StreamableLogic {
  state = { expanded: false };
  renderVals() {
    return {
      item: this.props.item || {},
      expanded: this.state.expanded,
      collapsed: !this.state.expanded,
      toggle: () => this.setState(s => ({ expanded: !s.expanded })),
    };
  }
}
\`\`\`

Note \`collapsed: !this.state.expanded\` — the template can't do \`{{ !expanded }}\`, so expose both flags.

# Anti-patterns — DO NOT

- **JS in template holes** — \`{{ items.length > 0 }}\`, \`{{ a + b }}\`, \`{{ fn() }}\` all fail silently (render as undefined). Compute in \`renderVals()\`.
- **Logic before templates** — writing \`Root.sc.ts\` before \`Root.sc.html\` means the user stares at a shimmer box while you emit invisible code.
- **Many small fast_mode_write calls** — one per component adds ~1.5s each. Batch into ONE call.
- **Missing \`hint-size\` on child refs** — placeholder defaults to 60px tall; layout jumps when the real template lands.
- **Forgetting Root** — nothing renders if there's no \`Root.sc.html\`.

---

# Layout templates

Most apps just want a normal scrolling Root. For two special cases — **slideshows** and **zoomable canvases** — use these Root patterns verbatim (adjust counts, sizes, and child names). They're proven to stream well: the fit/scale/pan logic should land early (see the "stream crucial logic" exception in Key Principles), so write the Root \`.sc.ts\` right after \`Root.sc.html\` before moving on to other components.

## SLIDES — fixed 1920×1080 deck, fit-to-viewport, keyboard + pill nav

\`\`\`html
<!-- Root.sc.html — one <sc-if> per slide; deck is scaled as a unit -->
<div style="position:fixed;inset:0;background:#000;display:flex;align-items:center;justify-content:center;overflow:hidden" ref="{{ stageRef }}">
  <div style="position:relative;width:1920px;height:1080px;transform-origin:center center;flex-shrink:0" ref="{{ deckRef }}">
    <sc-if value="{{ isSlide1 }}"><Slide1 hint-size="1920px,1080px" /></sc-if>
    <sc-if value="{{ isSlide2 }}"><Slide2 hint-size="1920px,1080px" /></sc-if>
    <sc-if value="{{ isSlide3 }}"><Slide3 hint-size="1920px,1080px" /></sc-if>
  </div>
  <div style="position:fixed;bottom:20px;left:50%;transform:translateX(-50%);display:flex;gap:4px;background:rgba(23,23,23,.88);backdrop-filter:blur(16px);padding:6px;border-radius:9999px;z-index:100;font-family:system-ui,sans-serif">
    <button onClick="{{ prev }}" style="background:transparent;border:none;width:32px;height:32px;border-radius:9999px;color:#e5e5e5;cursor:pointer">←</button>
    <div style="font-size:13px;color:#e5e5e5;min-width:52px;text-align:center;align-self:center;font-variant-numeric:tabular-nums">{{ currentDisplay }} / {{ total }}</div>
    <button onClick="{{ next }}" style="background:transparent;border:none;width:32px;height:32px;border-radius:9999px;color:#e5e5e5;cursor:pointer">→</button>
  </div>
</div>
\`\`\`

\`\`\`ts
// Root.sc.ts — slide index + fit-to-stage scaling + keyboard nav
const SLIDE_COUNT = 3;            // bump when adding slides
const DESIGN_W = 1920, DESIGN_H = 1080;
const STORAGE_KEY = 'deck_idx';

class Root extends StreamableLogic {
  state = { idx: 0 };
  stageRef = React.createRef();
  deckRef = React.createRef();
  componentDidMount() {
    try { const s = parseInt(localStorage.getItem(STORAGE_KEY) || '0', 10); if (s >= 0 && s < SLIDE_COUNT) this.setState({ idx: s }); } catch (e) {}
    this.resize = () => {
      const st = this.stageRef.current, d = this.deckRef.current; if (!d) return;
      const pw = st ? st.clientWidth : innerWidth, ph = st ? st.clientHeight : innerHeight;
      d.style.transform = 'scale(' + Math.min(pw / DESIGN_W, ph / DESIGN_H) + ')';
    };
    if (typeof ResizeObserver !== 'undefined' && this.stageRef.current) { this.ro = new ResizeObserver(this.resize); this.ro.observe(this.stageRef.current); }
    addEventListener('resize', this.resize); this.resize(); setTimeout(this.resize, 100); setTimeout(this.resize, 500);
    this.onKey = (e) => {
      if (e.key === 'ArrowRight' || e.key === ' ' || e.key === 'PageDown') { e.preventDefault(); this.next(); }
      if (e.key === 'ArrowLeft' || e.key === 'PageUp') { e.preventDefault(); this.prev(); }
    };
    addEventListener('keydown', this.onKey);
  }
  componentDidUpdate() { this.resize(); }
  componentWillUnmount() { removeEventListener('resize', this.resize); removeEventListener('keydown', this.onKey); if (this.ro) this.ro.disconnect(); }
  goTo(n) { const c = Math.max(0, Math.min(SLIDE_COUNT - 1, n)); this.setState({ idx: c }); try { localStorage.setItem(STORAGE_KEY, String(c)); } catch (e) {} }
  next = () => this.goTo(this.state.idx + 1);
  prev = () => this.goTo(this.state.idx - 1);
  renderVals() {
    const i = this.state.idx;
    return {
      isSlide1: i === 0, isSlide2: i === 1, isSlide3: i === 2,
      currentDisplay: i + 1, total: SLIDE_COUNT,
      next: this.next, prev: this.prev, stageRef: this.stageRef, deckRef: this.deckRef,
    };
  }
}
\`\`\`

Notes: one boolean per slide (\`isSlide1\`, \`isSlide2\`...) — templates can't do \`{{ idx === 0 }}\`. Each \`SlideN.sc.html\` is its own scomp, designed at full 1920×1080 (absolute-positioned children against that box).

## CANVAS — infinite pan/zoom with frames positioned by data

\`\`\`html
<!-- Root.sc.html — world layer gets a single transform; frames are absolute inside it -->
<div style="position:fixed;inset:0;background:#f5f5f4;overflow:hidden;user-select:none" ref="{{ stageRef }}" onMouseDown="{{ onMouseDown }}" onDoubleClick="{{ onDoubleClick }}">
  <div style="position:absolute;top:0;left:0;width:0;height:0;transform:{{ transform }};transform-origin:0 0;will-change:transform">
    <div style="position:absolute;left:-10000px;top:-10000px;width:20000px;height:20000px;background-image:radial-gradient(circle,#d6d3d1 1.2px,transparent 1.2px);background-size:32px 32px;pointer-events:none"></div>
    <sc-for list="{{ frames }}" as="frame" hint-placeholder-count="5">
      <CanvasFrame frame="{{ frame }}" hint-size="420px,900px" />
    </sc-for>
  </div>
</div>
\`\`\`

\`\`\`html
<!-- CanvasFrame.sc.html — positioned by frame.x/frame.y; dispatches to inner variant -->
<div style="position:absolute;left:{{ frame.x }}px;top:{{ frame.y }}px;width:420px">
  <div style="font-size:15px;color:#78716c;margin:0 4px 12px">{{ frame.title }}</div>
  <div style="width:420px;height:900px;background:#fff;border-radius:20px;overflow:hidden;box-shadow:0 8px 24px rgba(0,0,0,.06)">
    <sc-if value="{{ isLibrary }}"><FrameLibrary hint-size="100%,100%" /></sc-if>
    <sc-if value="{{ isPlayer }}"><FramePlayer hint-size="100%,100%" /></sc-if>
  </div>
</div>
\`\`\`

\`\`\`ts
// Root.sc.ts — pan (drag / two-finger scroll), pinch-zoom around cursor, fit-all
const MIN_SCALE = 0.1, MAX_SCALE = 4, STORAGE_KEY = 'canvas_view';

class Root extends StreamableLogic {
  state = { x: 0, y: 0, scale: 1 };
  stageEl = null; dragging = null; didInitialFit = false;
  frames = [
    { id: 'library', title: 'Library',     x: 0,   y: 200, variant: 'library' },
    { id: 'player',  title: 'Now playing', x: 500, y: 200, variant: 'player'  },
  ];
  // callback ref so we can attach non-passive wheel listener (React's onWheel is passive)
  stageRef = (el) => {
    if (this.stageEl === el) return;
    if (this.stageEl && this.wh) this.stageEl.removeEventListener('wheel', this.wh);
    this.stageEl = el;
    if (el) {
      this.wh = this.handleWheel.bind(this);
      el.addEventListener('wheel', this.wh, { passive: false });
      if (!this.didInitialFit) { this.didInitialFit = true; setTimeout(() => this.fitAll(), 50); }
    }
  };
  componentDidMount() {
    try { const s = JSON.parse(localStorage.getItem(STORAGE_KEY) || 'null'); if (s && typeof s.scale === 'number') { this.didInitialFit = true; this.setState(s); } } catch (e) {}
    addEventListener('mousemove', this.onMouseMove); addEventListener('mouseup', this.onMouseUp); addEventListener('keydown', this.onKeyDown);
  }
  componentWillUnmount() {
    if (this.stageEl && this.wh) this.stageEl.removeEventListener('wheel', this.wh);
    removeEventListener('mousemove', this.onMouseMove); removeEventListener('mouseup', this.onMouseUp); removeEventListener('keydown', this.onKeyDown);
  }
  setView(n) { const c = { x: n.x, y: n.y, scale: Math.max(MIN_SCALE, Math.min(MAX_SCALE, n.scale)) }; this.setState(c); try { localStorage.setItem(STORAGE_KEY, JSON.stringify(c)); } catch (e) {} }
  stagePt(e) { const r = this.stageEl.getBoundingClientRect(); return { px: e.clientX - r.left, py: e.clientY - r.top }; }
  // zoom around (px,py): keep the world point under cursor fixed
  zoomAt(px, py, factor) {
    const { x, y, scale } = this.state; const ns = Math.max(MIN_SCALE, Math.min(MAX_SCALE, scale * factor)); if (ns === scale) return;
    const wx = (px - x) / scale, wy = (py - y) / scale;
    this.setView({ x: px - wx * ns, y: py - wy * ns, scale: ns });
  }
  // browsers report trackpad pinch as wheel+ctrlKey; plain wheel is two-finger scroll
  handleWheel(e) {
    if (e.ctrlKey || e.metaKey) { e.preventDefault(); const { px, py } = this.stagePt(e); this.zoomAt(px, py, Math.exp(-e.deltaY * 0.01)); return; }
    e.preventDefault(); this.setView({ x: this.state.x - e.deltaX, y: this.state.y - e.deltaY, scale: this.state.scale });
  }
  onMouseDown = (e) => { if (e.button !== 0 || (e.target.closest && e.target.closest('button'))) return; this.dragging = { sx: e.clientX, sy: e.clientY, vx: this.state.x, vy: this.state.y }; document.body.style.cursor = 'grabbing'; };
  onMouseMove = (e) => { if (!this.dragging) return; this.setView({ x: this.dragging.vx + (e.clientX - this.dragging.sx), y: this.dragging.vy + (e.clientY - this.dragging.sy), scale: this.state.scale }); };
  onMouseUp = () => { if (this.dragging) { this.dragging = null; document.body.style.cursor = ''; } };
  onDoubleClick = (e) => { if (!(e.target.closest && e.target.closest('button'))) this.fitAll(); };
  onKeyDown = (e) => { if ((e.metaKey || e.ctrlKey) && (e.key === '0' || e.code === 'Digit0')) { e.preventDefault(); this.fitAll(); } };
  fitAll = () => {
    const st = this.stageEl; if (!st || !this.frames.length) return;
    const sw = st.clientWidth, sh = st.clientHeight; if (!sw || !sh) { setTimeout(this.fitAll, 100); return; }
    const FW = 420, FH = 900, PAD = 100;
    let minX = Infinity, minY = Infinity, maxX = -Infinity, maxY = -Infinity;
    for (const f of this.frames) { minX = Math.min(minX, f.x); minY = Math.min(minY, f.y); maxX = Math.max(maxX, f.x + FW); maxY = Math.max(maxY, f.y + FH); }
    const bw = maxX - minX, bh = maxY - minY;
    const scale = Math.max(MIN_SCALE, Math.min(MAX_SCALE, Math.min((sw - PAD * 2) / bw, (sh - PAD * 2) / bh)));
    const bcx = (minX + maxX) / 2, bcy = (minY + maxY) / 2;
    this.setView({ x: sw / 2 - bcx * scale, y: sh / 2 - bcy * scale, scale });
  };
  renderVals() {
    const { x, y, scale } = this.state;
    return {
      transform: 'translate(' + x + 'px, ' + y + 'px) scale(' + scale + ')',
      frames: this.frames, stageRef: this.stageRef,
      onMouseDown: this.onMouseDown, onDoubleClick: this.onDoubleClick,
    };
  }
}
\`\`\`

\`\`\`ts
// CanvasFrame.sc.ts — exposes one boolean per variant (templates can't compare strings)
class CanvasFrame extends StreamableLogic {
  renderVals() {
    const f = this.props.frame || {};
    return {
      frame: f,
      isLibrary: f.variant === 'library',
      isPlayer:  f.variant === 'player',
    };
  }
}
\`\`\`

Notes: the grid dot-pattern lives **inside** the world layer, so pan/zoom is one GPU transform (no repaint). Frame positions come from data (\`frame.x\`, \`frame.y\`) — the Root just iterates. The world div has \`width:0;height:0;transform-origin:0 0\` so math stays a plain affine transform.

For ordinary apps (dashboards, forms, landing pages, tools), skip both — write a normal Root component that lays out children with flex/grid.`;function Qq(e,t="blank"){let n;return t==="slides"?n=`Template: **slides**. A working \`<Slides>\` component is pre-installed as a plain React component at \`${e}/Slides.jsx\` — write content slides as direct children of \`<Slides>\` in \`Root.sc.html\`. Each child is one full-screen slide; style it with \`width:100%;height:100%;box-sizing:border-box;padding:Xpx\`. During streaming, \`<Slides>\` auto-jumps to the latest slide as you write it, so the user sees new slides appear live. Controls overlay at the bottom of the stage (frosted-glass pill). Keyboard: ← / → / space. The starter Root already has three example slides; replace or extend them. **Don't rewrite \`Slides.jsx\` unless you need to change its behavior.**`:t==="canvas"?n=`Template: **canvas**. A working \`<Canvas>\` component is pre-installed as a plain React component at \`${e}/Canvas.jsx\` — write frames as absolutely-positioned children of \`<Canvas>\` in \`Root.sc.html\`. Pan with mouse drag or scroll; zoom around the cursor with pinch or ctrl+wheel. The starter Root already has three example frames; replace or extend them. **Don't rewrite \`Canvas.jsx\` unless you need to change its behavior.**`:n="Template: **blank**. Start with the placeholder `Root.sc.html` and build from there.",_q+`

